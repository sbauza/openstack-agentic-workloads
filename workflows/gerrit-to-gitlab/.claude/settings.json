{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(artifacts/**)",
      "Bash(git *)",
      "Bash(glab *)",
      "Bash(docker *)",
      "Bash(workflows/shared/scripts/*)",
      "Bash(cd /workspace/repos/*)"
